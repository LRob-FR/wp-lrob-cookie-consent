#: src/Support/Presets.php:39
msgid ""
"We bake a few cookies to keep things running smoothly and to see what you "
"love most. Pick your flavour below — no hard feelings if you pass."
msgstr ""
"Nous préparons quelques cookies pour que tout roule et pour découvrir ce que "
"vous préférez. Choisissez votre parfum ci-dessous — aucun souci si vous "
"passez votre tour."

#: src/Support/Presets.php:40
msgid "Yes please"
msgstr "Oui, volontiers"

#: src/Support/Presets.php:41
msgid "No thanks"
msgstr "Non merci"

#: src/Support/Presets.php:42 src/Support/Presets.php:60
