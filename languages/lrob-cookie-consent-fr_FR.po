#. Plugin Name of the plugin
msgid "LRob - Cookie Consent"
msgstr "LRob - Cookie Consent"

#. Plugin URI of the plugin
msgid "https://www.lrob.fr/wordpress/plugins/lrob-cookie-consent/"
msgstr "https://www.lrob.fr/wordpress/plugins/lrob-cookie-consent/"

#. Description of the plugin
msgid ""
"Lean, opinionated GDPR / ePrivacy cookie consent — opt-in banner, script & "
"iframe blocking engine, proof of consent. No scanner, no bloat."
msgstr ""
"Consentement aux cookies RGPD / ePrivacy léger et bien pensé — bannière opt-"
"in, moteur de blocage des scripts et iframes, preuve de consentement. Sans "
"scanner, sans surcharge."

